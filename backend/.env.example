# Get a key from https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Any model slug supported by OpenRouter. Some good defaults:
#   openai/gpt-4o-mini       (fast & cheap, great for quizzes)
#   openai/gpt-4o            (higher quality)
#   anthropic/claude-3.5-sonnet
#   meta-llama/llama-3.1-70b-instruct
OPENROUTER_MODEL=openai/gpt-4o-mini

# Optional: shown on OpenRouter's leaderboard
OPENROUTER_SITE_URL=http://localhost:5173
OPENROUTER_APP_NAME=AI Quiz App

PORT=3001
